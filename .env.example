# =============================================================================
# Firebase & Vercel — how to use this file
# -----------------------------------------------------------------------------
# LOCAL (your PC)
#   Copy this file to `.env.local` in this folder, then fill in real values.
#   `.env.local` is gitignored — never commit it.
#
# VERCEL (GitHub deploy)
#   Vercel does NOT upload `.env.local` from your computer.
#   For each variable below: Vercel → your project → Settings → Environment
#   Variables → add the same name and value for Production (and Preview if you want).
#
#   Common mistakes:
#   - Variable exists only for "Development" — Production deploys won't see it. Enable Production.
#   - Names must match exactly: FIREBASE_PRIVATE_KEY (not PRIVATE_KEY or firebase_private_key).
#   - FIREBASE_PRIVATE_KEY: do NOT wrap the whole value in extra "quotes" in Vercel.
#     Use one line: -----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n
#     (the characters \ and n, not a real line break, unless you paste multi-line and Vercel keeps it).
#   - Client-side code needs NEXT_PUBLIC_* — Admin SDK vars are server-only (API routes); no NEXT_PUBLIC_ on them.
#
#   Or from this folder after logging in:  npx vercel env pull .env.vercel.local
#   (that downloads what you already saved in the Vercel dashboard)
# =============================================================================

# --- Firebase Admin (server / API routes) — REQUIRED on Vercel for QR / payments ---
# Firebase Console → Project settings → Service accounts → Generate new private key (JSON).
# Use the three fields below (do NOT commit the JSON file to GitHub).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Entire private_key from JSON as ONE line. Replace real newlines with the two characters \ and n
# Example shape (fake): "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# --- Firebase Web / client (NEXT_PUBLIC_* are embedded in the browser bundle) ---
# Firebase Console → Project settings → Your apps → Web app → SDK snippet / config.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Telegram (optional — alerts / entry & withdrawal approvals) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# --- Payment QR (optional) ---
# Paste the exact string your Paytm / merchant QR encodes (https://… or upi://…).
# For upi:// links without am=, the app appends am, cu, INR, and tn so the screen amount stays fixed per user.
# Or use {{amount}} / {{note}} in the string. If unset, the app builds from ENTRY_VPA in code.
NEXT_PUBLIC_ENTRY_PAY_QR_URL=
NEXT_PUBLIC_REEL_PAY_QR_URL=

# --- Razorpay (optional checkout) ---
AUTH_SESSION_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
